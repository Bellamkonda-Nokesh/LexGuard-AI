# LexGuard AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Required ──────────────────────────────────────────────────────
# Get your free API key at: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional: Google Cloud Services ────────────────────────────────
# Required only for persistent file storage (Cloud Storage)
GCS_BUCKET_NAME=

# Path to GCP service account JSON for Cloud Vision API (OCR)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Optional: Server Configuration ─────────────────────────────────
# Port for the FastAPI server (default: 8080)
PORT=8080

# Comma-separated list of allowed CORS origins (default: * for dev)
# In production: ALLOWED_ORIGINS=https://your-domain.com
ALLOWED_ORIGINS=*
